# OS files
.DS_Store
Thumbs.db

# Editor / IDE
.vs/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp

# Logs and temp
*.log
*.tmp
tmp/

# Git worktrees for parallel local editing (kept under the repo root, never committed)
.worktrees/

# Node (in case a plugin ships tooling)
node_modules/

# Python
__pycache__/
*.pyc
.venv/

# Plugin dev/test generated artifacts (never shipped)
test-results/
playwright-report/
.playwright-cli/
