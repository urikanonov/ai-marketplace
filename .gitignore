# OS files
.DS_Store
Thumbs.db

# Editor / IDE
.vs/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp

# Logs and temp
*.log
*.tmp

# Scratch space for temporary artifacts (see AGENTS.md, House style). The
# directory is tracked only by its .gitkeep; everything else inside is ignored,
# so temporary files never clutter the repo root or show up in git status.
tmp/*
!tmp/.gitkeep

# Git worktrees for parallel local editing (kept under the repo root, never committed)
.worktrees/

# Local feature/implementation plans (scratch space, never committed)
.plans/

# Node (in case a plugin ships tooling)
node_modules/

# Python
__pycache__/
*.pyc
.venv/
.coverage
.coverage.*
htmlcov/

# Plugin dev/test generated artifacts (never shipped)
test-results/
playwright-report/
.playwright-cli/
# AI-driven audit harness scratch output (dev/tools/audit.mjs)
audit_out/
audit-*/
plugins/tmp/

# Stray dist from a bare build.py run (default out-dir); the real dist is under pkg/
plugins/commentable-html/dev/dist/

# Scratch patch/diff dumps (never commit; use tmp/)
*.diff.txt

# Stray scratch dumped at the repo ROOT. Tooling and (sub-)agents sometimes write a `git diff`, an
# extracted copy of a source file, a probe script, or captured output at the repo root instead of
# tmp/ (see AGENTS.md rule 1 and House style). The repo root holds no code files, so ignore code /
# patch / diff / captured-output dumps HERE. Every pattern is root-anchored (leading /) so nothing
# under plugins/, scripts/, site/, or .github/ is ever hidden; add a `!/name` line if the root ever
# legitimately needs one of these.
/*.patch
/*.diff
/*.js
/*.mjs
/*.cjs
/*.ts
/*.py
/tmp_*
/out.txt
/out.json
/err.txt
