{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/urikanonov/ai-marketplace/.github/schemas/plugin.schema.json",
  "title": "Copilot CLI plugin manifest (plugin.json)",
  "type": "object",
  "required": ["name", "description", "version", "author"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$" },
    "author": {
      "type": "object",
      "required": ["name", "email"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "email": { "type": "string", "format": "email" }
      }
    },
    "keywords": { "type": "array", "items": { "type": "string" } },
    "license": { "type": "string" },
    "skills": { "type": "string" },
    "hooks": { "type": "string" }
  }
}
