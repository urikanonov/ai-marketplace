import java.util.List;

public class Sum {
    // Add all values in the list
    public static int total(List<Integer> values) {
        int sum = 0;
        for (int v : values) {
            sum += v;
        }
        return sum;
    }

    public static void main(String[] args) {
        /* prints 6 */
        System.out.println(total(List.of(1, 2, 3)));
    }
}
