// Fibonacci with memoization
const cache = new Map();

function fib(n) {
  if (n < 2) return n;
  if (cache.has(n)) return cache.get(n);
  const value = fib(n - 1) + fib(n - 2);
  cache.set(n, value);
  return value;
}

/* Print the first 10 numbers */
for (let i = 0; i < 10; i++) {
  console.log(`fib(${i}) = ${fib(i)}`);
}
