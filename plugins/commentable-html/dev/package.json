{
  "name": "commentable-html-dev",
  "private": true,
  "version": "2.5.0",
  "description": "Development harness, tests, and build tooling for the commentable-html plugin. Not distributed; the shipped skill lives in ../pkg.",
  "type": "module",
  "scripts": {
    "build": "python tools/build.py --assets-dir assets --out-dir ../pkg/skills/commentable-html",
    "build:check": "python tools/build.py --assets-dir assets --out-dir ../pkg/skills/commentable-html --check",
    "fixtures": "node tests/fixtures/generate.mjs",
    "fixtures:check": "node tests/fixtures/generate.mjs --check",
    "shots": "node tools/capture_tutorial.mjs",
    "test": "playwright test",
    "test:py": "python -m unittest discover -s tests -p \"test_*.py\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "adm-zip": "^0.6.0",
    "chart.js": "^4.5.1",
    "mermaid": "^11.16.0",
    "playwright": "^1.49.0"
  }
}
