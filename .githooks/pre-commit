#!/bin/sh
# Pre-commit hook: run the repo validators so a bad manifest, plugin, skill, or
# Markdown file cannot be committed locally (even by the owner, who can bypass branch protection).
#
# Enable once per clone:   git config core.hooksPath .githooks
# Skip for a single commit: git commit --no-verify

PY=python
command -v python >/dev/null 2>&1 || PY=python3
if ! command -v "$PY" >/dev/null 2>&1; then
  echo "pre-commit: python not found; skipping validation." >&2
  exit 0
fi

status=0

echo "pre-commit: validating Markdown..."
"$PY" scripts/validate_markdown.py || status=1

if "$PY" -c "import yaml, jsonschema" >/dev/null 2>&1; then
  echo "pre-commit: validating marketplace..."
  "$PY" scripts/validate_marketplace.py || status=1
else
  echo "pre-commit: marketplace validator deps missing; run 'pip install jsonschema pyyaml' to enable (skipping)." >&2
fi

if [ "$status" -ne 0 ]; then
  echo "pre-commit: validation failed; commit aborted. Fix the errors above, or use 'git commit --no-verify' to skip." >&2
fi
exit "$status"
