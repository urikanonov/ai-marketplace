#!/bin/sh
# Pre-push hook: run the deterministic checks that gate `main` in CI, so a push
# that would fail a required check is caught locally before the CI round-trip.
# The fast, reliable checks always run. The browser (Playwright) suites are
# slower and occasionally flaky, so they run only when RUN_E2E=1 is set - CI is
# the authoritative gate for them (the required `site` and `plugin-tests` checks).
#
# Enable once per clone:      git config core.hooksPath .githooks
# Skip for a single push:     git push --no-verify
# Also run the browser E2E:   RUN_E2E=1 git push

export LC_ALL=C

PY=""
for _cand in python python3; do
  if command -v "$_cand" >/dev/null 2>&1 && "$_cand" -c "" >/dev/null 2>&1; then
    PY=$_cand
    break
  fi
done
if [ -z "$PY" ]; then
  echo "pre-push: a working python was not found; skipping local checks (CI will still run them)." >&2
  exit 0
fi

status=0
run() {
  _desc=$1
  shift
  echo "pre-push: $_desc"
  if ! "$@"; then
    echo "pre-push: FAILED - $_desc" >&2
    status=1
  fi
}

# Mirrors the required `validate` job: Markdown hygiene, manifest/plugin/skill
# validation, no-Backlog guard, script unit tests, and the changelog sync + history guard.
run "Markdown hygiene" "$PY" scripts/validate_markdown.py

if "$PY" -c "import yaml, jsonschema" >/dev/null 2>&1; then
  run "marketplace manifest, plugins, and skills" "$PY" scripts/validate_marketplace.py
else
  echo "pre-push: marketplace validator deps missing; 'pip install jsonschema pyyaml' to enable (skipping)." >&2
fi

run "script unit tests" "$PY" -m unittest discover -s scripts -p "test_*.py"
run "spec test references" "$PY" scripts/check_spec_test_refs.py
run "doc-surface declarations for new features" "$PY" scripts/check_doc_surfaces.py
run "forbidden secret-bearing files" "$PY" scripts/check_forbidden_files.py
run "Backlog.md artifacts absent" "$PY" scripts/check_no_backlog.py

# Plugin Python suites. By default only the suites of plugins changed versus origin/main
# run, so a docs/scripts/site-only push does not rerun every plugin's suite (the slow part
# of this hook). Set PREPUSH_FULL=1 to run them all. CI shards and always runs the full set.
if [ "${PREPUSH_FULL:-0}" = "1" ] || ! git rev-parse --verify --quiet origin/main >/dev/null 2>&1; then
  run "plugin Python tests (all)" "$PY" scripts/run_plugin_python_tests.py --require-discovered
else
  run "plugin Python tests (changed plugins vs origin/main; PREPUSH_FULL=1 for all)" \
    "$PY" scripts/run_plugin_python_tests.py --changed-only --base-ref origin/main
fi

# These two need origin/main to diff against, so guard them on it being fetched
# (they mirror the required `validate` changelog step and the `version-bump` job).
if git rev-parse --verify --quiet origin/main >/dev/null 2>&1; then
  run "changelog sync and released-history guard" "$PY" scripts/check_changelog_sync.py
  run "version bump for changed plugins" "$PY" scripts/check_version_bump.py
else
  echo "pre-push: origin/main not found locally; 'git fetch origin' to enable the changelog-sync and version-bump checks (skipping)." >&2
fi

# Mirrors the required `site` (site drift) and `dist-in-sync` (layer dist) jobs.
run "site data in sync (build_site_data --check)" "$PY" scripts/build_site_data.py --check
run "commentable-html layer dist in sync (build.py --check)" "$PY" \
  plugins/commentable-html/dev/tools/build.py \
  --assets-dir plugins/commentable-html/dev/assets \
  --out-dir plugins/commentable-html/dev/skill \
  --pkg-dir plugins/commentable-html/pkg/skills/commentable-html \
  --examples-dir plugins/commentable-html/examples --check

if command -v node >/dev/null 2>&1; then
  run "commentable-html test fixtures in sync (generate.mjs --check)" \
    node plugins/commentable-html/dev/tests/fixtures/generate.mjs --check
else
  echo "pre-push: node not found; skipping the fixtures --check (CI will run it)." >&2
fi

# Browser E2E suites: opt-in. CI runs them on every PR as the required `site`
# (site) and `plugin-tests` (plugin) checks, so a push that regresses them is caught
# there; running them locally is available with RUN_E2E=1 for a full pre-push.
if [ "${RUN_E2E:-0}" = "1" ]; then
  if command -v node >/dev/null 2>&1; then
    # site/tests plus every plugin dev suite, discovered the way the plugin-tests CI
    # `discover` job does (plugins/*/dev/package.json), so a new plugin suite is picked
    # up automatically instead of silently skipped.
    suites="site/tests"
    for _pkg in plugins/*/dev/package.json; do
      [ -f "$_pkg" ] && suites="$suites ${_pkg%/package.json}"
    done
    for suite in $suites; do
      if [ -d "$suite/node_modules" ]; then
        echo "pre-push: Playwright suite ($suite)"
        ( cd "$suite" && npm test ) || { echo "pre-push: FAILED - Playwright ($suite)" >&2; status=1; }
      else
        echo "pre-push: RUN_E2E set but $suite/node_modules is missing; run 'npm ci' there first (skipping)." >&2
      fi
    done
  else
    echo "pre-push: RUN_E2E set but node not found; skipping the Playwright suites." >&2
  fi
else
  echo "pre-push: browser E2E skipped (set RUN_E2E=1 to run the Playwright suites; CI runs them on every PR)."
fi

if [ "$status" -ne 0 ]; then
  echo "pre-push: checks failed; push aborted. Fix the errors above, or use 'git push --no-verify' to skip." >&2
fi
exit "$status"
